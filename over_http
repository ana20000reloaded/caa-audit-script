except urllib.error.HTTPError as e:

    if e.code in (404,502,504):

        print(
            f"{e.code} retry "
            f"in {delay}s"
        )

        time.sleep(delay)

        delay *= 2

        continue

    print(
        "HTTP error",
        e.code,
        "for",
        domain,
        "- skipping"
    )

    return []
