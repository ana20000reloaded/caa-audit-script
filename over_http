domains.txt
  ↓
batch / loop (one domain at a time)
  ↓
https://crt.sh/?q=<domain>&output=json
  ↓
filter locally:
   - valid cert only
   - issuer not approved
   - deduplicate by certificate ID
  ↓
JSON + CSV + TXT output


import urllib.request
import urllib.parse
import json
from datetime import datetime, timezone

# Approved issuers
APPROVED_CA_IDS = {
    172211,
    30252,
    107462,
    163648
}

domain = "agenziadb.it"


def cert_valid(cert):
    nb = datetime.fromisoformat(
        cert["not_before"].replace("Z","+00:00")
    )

    na = datetime.fromisoformat(
        cert["not_after"].replace("Z","+00:00")
    )

    now = datetime.now(timezone.utc)

    return nb <= now <= na


url = (
    "https://crt.sh/?q="
    + urllib.parse.quote(domain)
    + "&output=json"
)

print("Fetching", url)

with urllib.request.urlopen(url) as r:
    rows = json.loads(r.read().decode())

print("Rows returned:", len(rows))


seen = set()

for cert in rows:

    cert_id = cert["id"]

    if cert_id in seen:
        print("Duplicate cert:", cert_id)
        continue

    seen.add(cert_id)

    ca_id = int(cert["issuer_ca_id"])

    # skip approved CAs
    if ca_id in APPROVED_CA_IDS:
        continue

    # skip expired / not yet valid
    if not cert_valid(cert):
        continue

    print()
    print("VIOLATION FOUND")
    print("Cert ID:", cert_id)
    print("Issuer CA ID:", ca_id)
    print("Issuer:", cert["issuer_name"])
    print("Serial:", cert["serial_number"])
    print("Valid from:", cert["not_before"])
    print("Valid to:", cert["not_after"])
    print("Domains:")
    print(cert["name_value"])
