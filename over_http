import urllib.request
import json

domain = "example.com"

url = f"https://crt.sh/?q={domain}&output=json"

print("Fetching:", url)

with urllib.request.urlopen(url, timeout=20) as r:
    data = json.loads(r.read().decode())

print("Returned rows:", len(data))

if data:
    print("Sample keys:", data[0].keys())
